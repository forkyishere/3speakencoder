# 3Speak Encoder Configuration
# Copy this file to .env and fill in your actual values
# ⚠️  NEVER commit your .env file to version control!

# Hive Account Configuration (required)
HIVE_USERNAME=your-hive-username

# 🚨 CRITICAL: DID Identity Authentication Key (REQUIRED for persistent identity)
ENCODER_PRIVATE_KEY=generate-and-paste-your-key-here

# ⚠️  WITHOUT THIS KEY:
#     • Your encoder gets a new identity on every restart
#     • Dashboard tracking breaks (shows "new encoder" each time)
#     • Job attribution doesn't persist across sessions
# 
# 🔧 TO GENERATE A NEW KEY:
#     Run: node -e "console.log('ENCODER_PRIVATE_KEY=' + require('crypto').randomBytes(32).toString('base64'))"
#     Copy the output here and replace the placeholder above
# 
# ✅ This creates your DID identity for JWS signatures
# ✅ This is NOT your Hive private key
# ✅ This is only for encoder-gateway authentication  
# ✅ Keep this secret - never share publicly
# ✅ Same key = same encoder identity forever

# Gateway Configuration
GATEWAY_URL=https://encoder.3speak.tv
QUEUE_MAX_LENGTH=1
QUEUE_CONCURRENCY=1
ASYNC_UPLOADS=false
REMOTE_GATEWAY_ENABLED=true

# IPFS Configuration
# Local or remote IPFS API address (multiaddr format)
# Use localhost for local IPFS daemon: /ip4/127.0.0.1/tcp/5001
# Use remote IPFS node: /ip4/192.168.1.100/tcp/5001
IPFS_API_ADDR=/ip4/127.0.0.1/tcp/5001

# 3Speak IPFS Infrastructure (critical for uploads)


# Traffic Director for Hotnode Upload (automatic load balancing)
TRAFFIC_DIRECTOR_URL=https://cdn.3speak.tv/api/hotnode

# IPFS Cluster Support (optional - reduces main daemon load)
USE_CLUSTER_FOR_PINS=false


# Local Fallback Pinning (optional - for 3Speak-operated encoder nodes)
ENABLE_LOCAL_FALLBACK=false
LOCAL_FALLBACK_THRESHOLD=3
REMOVE_LOCAL_AFTER_SYNC=true

# Encoder Configuration
TEMP_DIR=./temp
FFMPEG_PATH=/usr/bin/ffmpeg
HARDWARE_ACCELERATION=true
MAX_CONCURRENT_JOBS=1

# Download Acceleration (optional — requires aria2 installed, see README)
# ARIA2_CONNECTIONS=12   # Parallel connections per download (tune for your latency: 4–16)

# Node Configuration
NODE_NAME=3speak-encoder-node

# Direct API Configuration (optional - for miniservice integration)
DIRECT_API_ENABLED=false
DIRECT_API_PORT=3002
# 🔐 Generate a secure random key if enabling direct API:
# DIRECT_API_KEY=generate-a-long-random-secure-key-here
# ⚠️  Keep this secret - it controls access to your encoder API!

# MongoDB Direct Verification (DISABLED by default)
# 🚨 CRITICAL: Only enable this for 3Speak infrastructure nodes
# 🔐 This provides direct database verification when gateway APIs fail
# 🔐 Requires MongoDB credentials - contact 3Speak team for access
MONGODB_VERIFICATION_ENABLED=false
# MONGODB_URI=mongodb://username:password@host:port/database
# DATABASE_NAME=spk-encoder-gateway
# MONGODB_CONNECTION_TIMEOUT=10000
# MONGODB_SOCKET_TIMEOUT=30000

# IPFS Storage Administration (LOCAL IPFS NODES)
# 🔐 Password protection for IPFS storage management features
# Requires ENABLE_LOCAL_FALLBACK=true (local IPFS daemon running)
# Available for both infrastructure and community nodes with local IPFS
STORAGE_ADMIN_PASSWORD=
# Set a strong password here - this enables:
# • IPFS pin listing and management
# • Migration of pins to supernode
# • Batch operations and garbage collection
# • Storage statistics and monitoring
# ⚠️  Only enable if you have local IPFS daemon and want to manage pins

# =================================================================
# GATEWAY AID FALLBACK (APPROVED COMMUNITY NODES ONLY)
# =================================================================
# Gateway Aid provides REST API fallback when websocket/gateway APIs fail
# 
# ⚠️  REQUIRES APPROVAL: Your DID key must be registered with 3Speak
# ⚠️  Contact 3Speak team to request Gateway Aid access
# 
# This is NOT available by default - only for approved community encoders
# Infrastructure nodes should use MongoDB fallback instead (MONGO_URI)
#
# When enabled, if gateway websocket or APIs fail, encoder will automatically
# switch to REST API endpoints for job claiming, progress updates, and completion
#
GATEWAY_AID_ENABLED=false
# GATEWAY_AID_PRIMARY=false
# GATEWAY_AID_BASE_URL=https://gateway-monitor.3speak.tv/aid/v1

# ============================================================================
# GATEWAY MONITOR (Community Encoders - Stats & Verification)
# ============================================================================
# 🌐 Public REST API for job statistics and verification
# 
# For community encoders, this provides:
# • Job availability counts for dashboard
# • Rescue mode statistics  
# • Job ownership verification (prevents race conditions)
#
GATEWAY_MONITOR_ENABLED=false
# GATEWAY_MONITOR_BASE_URL=https://gateway-monitor.3speak.tv/api

# ============================================================================
# IPFS GATEWAY (Public Video Access)
# ============================================================================
# 🌐 Public IPFS gateway for downloading and verifying videos
# Used for:
# • Downloading source videos from IPFS when re-encoding
# • Verifying uploaded content accessibility
# • Manual CID verification links in logs
#
# IPFS_GATEWAY_URL=https://ipfs.3speak.tv
